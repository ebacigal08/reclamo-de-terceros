# ─────────────────────────────────────────────────────────────
# Amparo CRM — variables de entorno
# Copiá este archivo a .env.local y completá los valores.
# ─────────────────────────────────────────────────────────────

# URL del deployment de Convex (la genera `npx convex dev` la primera vez).
# Es pública: la usa el cliente para conectarse al backend.
NEXT_PUBLIC_CONVEX_URL=

# Solo para CI / Railway: clave de deploy de Convex.
# Se usa en el build de producción: `npx convex deploy --cmd 'npm run build'`.
# Generála en el dashboard de Convex → Settings → Deploy Keys.
CONVEX_DEPLOY_KEY=
