{
  "name": "amparo-crm",
  "version": "0.1.0",
  "private": true,
  "description": "CRM Siniestros AR — Amparo. Next.js + Convex.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "dev:convex": "convex dev",
    "prebuild": "node scripts/verificar-deploy.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "typecheck:convex": "tsc -p convex/tsconfig.json",
    "deploy:staging": "convex deploy --env-file .env.staging.local",
    "dev:staging": "convex dev --once --env-file .env.staging.local"
  },
  "dependencies": {
    "@auth/core": "^0.41.2",
    "@convex-dev/auth": "^0.0.94",
    "convex": "^1.17.4",
    "lucide-react": "^0.469.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3"
  }
}
